#
# BANANAPI-R64 -- BANANAPI-R64 kernel configuration file for FreeBSD/arm64
#

cpu		ARM64
ident		BANANAPI-R64

include		"std.arm64"
include		"std.dev"

makeoptions     DEBUG=-g  # Enable kernel debugging sybmbols
options KDB
options DDB               # built-in DDB support
options GDB               # enter GDB from DDB
options KDB_TRACE
options BREAK_TO_DEBUGGER # If need to enter DDB from console

# Include SoC specific configuration
include		"std.mediatek"
